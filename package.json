{
  "name": "pharmacy-invoices",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "verify:env": "node -e \"console.log('Env template present:', require('fs').existsSync('.env.example'))\"",
    "setup:db": "npm run db:up && npm --workspace backend exec prisma migrate dev --name init && npm --workspace backend run db:seed"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10"
}


