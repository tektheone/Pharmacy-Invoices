{
  "name": "pharmacy-invoices",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "verify:env": "node -e \"console.log('Env template present:', require('fs').existsSync('.env.example'))\"",
    "setup:db": "npm run db:up && sleep 10 && npm --workspace backend exec prisma migrate dev --name init && npm --workspace backend run db:seed",
    "dev:backend": "npm --workspace backend run dev",
    "build:backend": "npm --workspace backend run build",
    "test:backend": "npm --workspace backend run test",
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "preview:frontend": "npm --workspace frontend run preview"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10"
}


